skinparam backgroundColor #F9FAFB
skinparam defaultFontSize 11
class PayrollController as "PayrollController\n工资核算控制" #EEF2FF {
  - calculationService: SalaryCalculationService
  - excelService: ExcelService
  - logService: OperationLogService
  ..
  + calculate(req, httpReq): ApiResponse<List<SalaryRecord>>
