@startuml
skinparam backgroundColor #F9FAFB
skinparam defaultFontSize 12
class TaxConfig as "TaxConfig\n个税税率" #FCE7F3 {
  - id: Long
  - level: Integer
  - minIncome: Double
  - maxIncome: Double
  - taxRate: Double
  - quickDeduction: Double
  - year: Integer
  - active: Boolean
}
note right of TaxConfig : PK, 表: sys_tax_config\nlevel: column=tax_level, 1~7级\ntaxRate: %, NOT NULL\nquickDeduction: 速算扣除数\nyear: column=tax_year
@enduml
